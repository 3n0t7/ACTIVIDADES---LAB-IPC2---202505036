<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Control Académico USAC</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- ── Barra de Navegación ── -->
