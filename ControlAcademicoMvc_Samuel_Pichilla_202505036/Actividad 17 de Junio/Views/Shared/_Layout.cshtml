        <div class="nav-brand">
            <span class="nav-logo">&#127979;</span>
            <span class="nav-title">Control Académico — IPC2</span>
        </div>
        <ul class="nav-links">
            <li><a href="/">Inicio</a></li>
            <li><a href="/Estudiante/Listar">Estudiantes</a></li>
        </ul>
    </nav>

    <!-- ── Contenido Principal (inyectado por cada Vista) ── -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- ── Pie de Página ── -->
    <footer class="footer">
        <div>
            <strong>Universidad de San Carlos de Guatemala</strong> — Facultad de Ingeniería
        </div>
        <div>
            Introducción a la Programación y Computación 2 | Laboratorio A |
            Samuel Esteban Pichillá Duartes — 202505036
        </div>
    </footer>

